#!/usr/bin/env bash
# devbox — manage devbox containers
#
# Usage: devbox <command> [args]
# Run 'devbox help' or 'devbox help <command>' for details.

set -euo pipefail

# ── Remote proxy ──────────────────────────────────────────────────────────────
# If DEVBOX_HOST is set, forward all commands to that host over SSH.
# Set this on your local machine to use devbox as if you were on the server:
#   export DEVBOX_HOST=ds9   # in ~/.bashrc
if [[ -n "${DEVBOX_HOST:-}" ]]; then
    case "${1:-}" in
        ssh|code|zed) ;;  # open local apps — must run on this machine, not the server
        *) exec ssh "$DEVBOX_HOST" devbox "$@" ;;
    esac
fi

# ── Config ────────────────────────────────────────────────────────────────────

DEVBOX_IMAGE="${DEVBOX_IMAGE:-devbox-base}"
DATA_ROOT="${DEVBOX_DATA_ROOT:-/data/devboxes}"
STATE_FILE="${DATA_ROOT}/.state.json"
CONFIG_FILE="${DEVBOX_CONFIG:-/etc/devbox/config}"
LOG_DIR="/var/log/devbox"
SSH_PUBKEY_FILE="${ssh_pubkey_file:-$HOME/.ssh/authorized_keys}"

# ── Word lists ────────────────────────────────────────────────────────────────

ADJECTIVES=(
    clever swift silent golden cosmic vivid rugged hollow bright amber
    noble steady fierce gentle rapid lunar solar arctic ember frozen
    ancient daring electric fleeting serene nimble dazzling curious valiant
    stormy radiant midnight crystal phantom silver obsidian cobalt crimson
)

NOUNS=(
    otter falcon raven panda gecko crane heron badger cobra lynx
    meerkat narwhal osprey puffin quasar nebula comet pulsar vortex
    bastion citadel summit canyon glacier mesa delta fjord tundra
    nomad pilgrim ranger herald cipher beacon vector prism lantern
    compass anchor scepter
)

# ── Helpers ───────────────────────────────────────────────────────────────────

log() { echo "[devbox] $*"; }
err() { echo "[devbox] error: $*" >&2; }
die() { err "$*"; exit 1; }

load_config() {
    [[ -f "$CONFIG_FILE" ]] && source "$CONFIG_FILE" || true
}

random_name() {
    echo "${ADJECTIVES[$((RANDOM % ${#ADJECTIVES[@]}))]}-${NOUNS[$((RANDOM % ${#NOUNS[@]}))]}"
}

# ── State file ────────────────────────────────────────────────────────────────

state_get() {
    local name="$1" path="$2"
    [[ -f "$STATE_FILE" ]] || { echo ""; return; }
    jq -r --arg name "$name" ".[\$name]${path} // empty" "$STATE_FILE" 2>/dev/null || true
}

state_set() {
    local name="$1" key="$2" value="$3" tmp
    mkdir -p "$(dirname "$STATE_FILE")"
    [[ -f "$STATE_FILE" ]] || echo '{}' > "$STATE_FILE"
    tmp=$(mktemp)
    jq --arg name "$name" --arg key "$key" --argjson val "$value" \
        '.[$name][$key] = $val' "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
}

state_set_share() {
    local name="$1" active="$2" url="${3:-}" port="${4:-80}" tmp
    mkdir -p "$(dirname "$STATE_FILE")"
    [[ -f "$STATE_FILE" ]] || echo '{}' > "$STATE_FILE"
    tmp=$(mktemp)
    jq --arg name "$name" \
       --argjson active "$active" \
       --arg url "$url" \
       --argjson port "$port" \
       '.[$name].share = {"active": $active, "url": $url, "port": $port}' \
       "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
}

# Extract the container mount point from a Docker volume spec (host:container[:opts]).
# Used for collision detection when merging auto-mounts with explicit volumes.
_container_path() {
    local spec="$1" parts
    IFS=':' read -ra parts <<< "$spec"
    [[ ${#parts[@]} -ge 2 ]] && echo "${parts[1]}" || echo "${parts[0]}"
}

state_set_volumes() {
    local name="$1" tmp
    shift
    local volumes_json="[]"
    [[ $# -gt 0 ]] && volumes_json=$(printf '%s\n' "$@" | jq -R . | jq -s .)
    mkdir -p "$(dirname "$STATE_FILE")"
    [[ -f "$STATE_FILE" ]] || echo '{}' > "$STATE_FILE"
    tmp=$(mktemp)
    jq --arg name "$name" --argjson vols "$volumes_json" \
        '.[$name].volumes = $vols' "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
}

state_delete() {
    local name="$1" tmp
    [[ -f "$STATE_FILE" ]] || return 0
    tmp=$(mktemp)
    jq --arg name "$name" 'del(.[$name])' "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
}

# ── Tailscale ─────────────────────────────────────────────────────────────────

# Exchange OAuth client credentials for a short-lived API token.
# OAuth clients don't expire (unlike API access tokens which cap at 90 days).
# Create one at: Tailscale admin → Settings → Trust Credentials → OAuth Clients
# Required grants: Keys → Auth Keys (write), Devices → Core (read + write)
_tailscale_token() {
    [[ -n "${TAILSCALE_CLIENT_ID:-}"     ]] || die "TAILSCALE_CLIENT_ID not set in ${CONFIG_FILE}"
    [[ -n "${TAILSCALE_CLIENT_SECRET:-}" ]] || die "TAILSCALE_CLIENT_SECRET not set in ${CONFIG_FILE}"

    local token
    token=$(curl -sf -X POST https://api.tailscale.com/api/v2/oauth/token \
        -d "client_id=${TAILSCALE_CLIENT_ID}" \
        -d "client_secret=${TAILSCALE_CLIENT_SECRET}" \
        -d "grant_type=client_credentials" \
        | jq -r '.access_token') || \
        die "Failed to get Tailscale OAuth token. Check TAILSCALE_CLIENT_ID and TAILSCALE_CLIENT_SECRET in ${CONFIG_FILE}."
    echo "$token"
}

generate_tailscale_key() {
    [[ -n "${TAILSCALE_TAILNET:-}" ]] || die "TAILSCALE_TAILNET not set in ${CONFIG_FILE}"

    local token response
    token=$(_tailscale_token)

    response=$(curl -sf -X POST \
        -H "Authorization: Bearer ${token}" \
        -H "Content-Type: application/json" \
        -d '{
            "capabilities": {
                "devices": {
                    "create": {
                        "reusable": false,
                        "ephemeral": true,
                        "preauthorized": true,
                        "tags": ["tag:devbox"]
                    }
                }
            },
            "expirySeconds": 300
        }' \
        "https://api.tailscale.com/api/v2/tailnet/${TAILSCALE_TAILNET}/keys") || \
        die "Failed to create Tailscale auth key. Check TAILSCALE_TAILNET in ${CONFIG_FILE}."

    echo "$response" | jq -r '.key'
}

wait_for_tailscale_ip() {
    local name="$1" container="devbox-${1}" attempts=0
    while [[ $attempts -lt 20 ]]; do
        local ip
        ip=$(docker exec "$container" tailscale ip -4 2>/dev/null || true)
        [[ -n "$ip" ]] && { echo "$ip"; return 0; }
        sleep 3
        attempts=$(( attempts + 1 ))
    done
    echo ""
}

remove_tailscale_node() {
    local name="$1"
    if [[ -z "${TAILSCALE_CLIENT_ID:-}" || -z "${TAILSCALE_CLIENT_SECRET:-}" || -z "${TAILSCALE_TAILNET:-}" ]]; then
        log "Warning: Tailscale credentials not set — skipping node removal."
        return 0
    fi

    local token
    token=$(_tailscale_token) || {
        log "Warning: Could not get Tailscale token — skipping node removal."
        return 0
    }

    local devices_json node_id
    devices_json=$(curl -sf \
        -H "Authorization: Bearer ${token}" \
        "https://api.tailscale.com/api/v2/tailnet/${TAILSCALE_TAILNET}/devices") || {
        log "Warning: Could not list Tailscale devices — skipping node removal."
        return 0
    }

    node_id=$(echo "$devices_json" | jq -r --arg name "$name" \
        '.devices[] | select(.hostname == $name) | .id' | head -1)

    if [[ -z "$node_id" ]]; then
        log "No Tailscale node found for '${name}'."
        return 0
    fi

    curl -sf -X DELETE -o /dev/null \
        -H "Authorization: Bearer ${token}" \
        "https://api.tailscale.com/api/v2/device/${node_id}" && \
        log "Tailscale node '${name}' removed." || \
        log "Warning: Failed to remove Tailscale node ${node_id}."
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_list() {
    local containers
    containers=$(docker ps -a --filter 'name=devbox-' --format '{{.Names}}\t{{.Status}}' 2>/dev/null || true)

    # Build set of names that have a container
    local -A _has_container=()
    while IFS=$'\t' read -r container_name _; do
        [[ -n "$container_name" ]] && _has_container["${container_name#devbox-}"]=1
    done <<< "$containers"

    # Find data dirs with no corresponding container
    local -a orphans=()
    if [[ -d "$DATA_ROOT" ]]; then
        for _dir in "$DATA_ROOT"/*/; do
            [[ -d "$_dir" ]] || continue
            local _dname
            _dname=$(basename "$_dir")
            [[ "${_has_container[$_dname]+set}" ]] || orphans+=("$_dname")
        done
    fi

    if [[ -z "$containers" && ${#orphans[@]} -eq 0 ]]; then
        echo "No devboxes found."
        return 0
    fi

    printf "%-20s %-10s %-8s %-8s %s\n" "NAME" "STATUS" "PINNED" "SHARED" "URL"
    printf "%-20s %-10s %-8s %-8s %s\n" "----" "------" "------" "------" "---"

    while IFS=$'\t' read -r container_name status_raw; do
        [[ -n "$container_name" ]] || continue
        local name="${container_name#devbox-}"
        local status="stopped"
        [[ "$status_raw" == Up* ]] && status="running"

        local pinned shared url
        pinned=$(state_get "$name" '.pinned // false')
        shared=$(state_get  "$name" '.share.active // false')
        url=$(state_get     "$name" '.share.url // ""')

        [[ "$pinned" == "true" ]] && pinned="yes" || pinned="no"
        [[ "$shared" == "true" ]] && shared="yes" || shared="no"

        printf "%-20s %-10s %-8s %-8s %s\n" "$name" "$status" "$pinned" "$shared" "$url"
    done <<< "$containers"

    for _oname in "${orphans[@]}"; do
        printf "%-20s %-10s %-8s %-8s %s\n" "$_oname" "orphaned" "-" "-" ""
    done
}

# Shared docker run logic used by cmd_create, cmd_start, cmd_reconfigure, and _full_recreate.
# Spins up a brand-new container. Callers handle stop/rm of any prior container.
# Args: <name> <pin: true|false> <idle_timeout> <log_file|""> [volume-specs...]
# Callers must have called load_config first.
_docker_run_devbox() {
    local name="$1" pin="$2" idle_timeout="$3" log_file="$4"
    shift 4
    local volumes=("$@")
    local container="devbox-${name}"
    local data_dir="${DATA_ROOT}/${name}"

    mkdir -p "$data_dir" "$LOG_DIR"

    local ts_auth_key
    ts_auth_key=$(generate_tailscale_key)

    local ssh_pubkey=""
    [[ -n "${DEVBOX_SSH_PUBKEY:-}" ]] && ssh_pubkey="$DEVBOX_SSH_PUBKEY"
    [[ -z "$ssh_pubkey" && -f "$SSH_PUBKEY_FILE" ]] && ssh_pubkey=$(cat "$SSH_PUBKEY_FILE")
    [[ -z "$ssh_pubkey" ]] && log "Warning: No SSH public key found. Set DEVBOX_SSH_PUBKEY or populate ${SSH_PUBKEY_FILE}."

    local extra_args=()
    [[ -n "${DEVBOX_GITHUB_TOKEN:-}" ]]      && extra_args+=(-e "GH_TOKEN=${DEVBOX_GITHUB_TOKEN}")
    [[ -n "${DEVBOX_DOTFILES_REPO:-}" ]]     && extra_args+=(-e "DEVBOX_DOTFILES_REPO=${DEVBOX_DOTFILES_REPO}")
    [[ -n "${DEVBOX_DOTFILES_INIT:-}" ]]     && extra_args+=(-e "DEVBOX_DOTFILES_INIT=${DEVBOX_DOTFILES_INIT}")
    [[ -n "${DEVBOX_ATUIN_USERNAME:-}" ]]    && extra_args+=(-e "ATUIN_USERNAME=${DEVBOX_ATUIN_USERNAME}")
    [[ -n "${DEVBOX_ATUIN_PASSWORD:-}" ]]    && extra_args+=(-e "ATUIN_PASSWORD=${DEVBOX_ATUIN_PASSWORD}")
    [[ -n "${DEVBOX_ATUIN_KEY:-}" ]]         && extra_args+=(-e "ATUIN_KEY=${DEVBOX_ATUIN_KEY}")
    [[ -n "${DEVBOX_ATUIN_SERVER_URL:-}" ]]  && extra_args+=(-e "ATUIN_SYNC_ADDRESS=${DEVBOX_ATUIN_SERVER_URL}")

    local volume_args=()
    for _vol in "${volumes[@]}"; do volume_args+=(-v "$_vol"); done

    local run_cmd=(
        docker run -d
        --name "$container"
        --hostname "$name"
        --cap-add=NET_ADMIN
        --device=/dev/net/tun
        -v "${data_dir}:/workspace"
        "${volume_args[@]}"
        -e "TAILSCALE_AUTH_KEY=${ts_auth_key}"
        -e "DEVBOX_IDLE_TIMEOUT=${idle_timeout}"
        -e "DEVBOX_NAME=${name}"
        -e "DEVBOX_USER=$(whoami)"
        -e "DEVBOX_USER_UID=$(id -u)"
        -e "DEVBOX_SSH_PUBKEY=${ssh_pubkey}"
        "${extra_args[@]}"
        "$DEVBOX_IMAGE"
    )

    if [[ -n "$log_file" ]]; then
        "${run_cmd[@]}" >> "$log_file" 2>&1 || return 1
    else
        "${run_cmd[@]}" > /dev/null || return 1
    fi

    state_set "$name" "pinned" "$([[ "$pin" == "true" ]] && echo 'true' || echo 'false')"
    state_set_volumes "$name" "${volumes[@]}"
    ssh-keygen -R "$name" &>/dev/null || true
}

# Resolve --mount flag names to volume specs using DEVBOX_MOUNT_* config vars.
# Appends results to the named array variable.
_resolve_mounts() {
    local -n _arr="$1"; shift
    for _mount_name in "$@"; do
        local _key="${_mount_name//-/_}"
        local _var="DEVBOX_MOUNT_${_key}"
        local _val="${!_var:-}"
        [[ -n "$_val" ]] || die "--mount '${_mount_name}': DEVBOX_MOUNT_${_key} not set in ${CONFIG_FILE}"
        _arr+=("$_val")
    done
}

# Apply DEVBOX_AUTO_MOUNTS to volumes, skipping anything that conflicts with already-claimed container paths.
_apply_auto_mounts() {
    local -n _arr="$1"
    [[ -n "${DEVBOX_AUTO_MOUNTS:-}" ]] || return 0
    local -A _claimed=()
    for _vol in "${_arr[@]}"; do _claimed["$(_container_path "$_vol")"]=1; done
    for _auto_name in $DEVBOX_AUTO_MOUNTS; do
        local _auto_key="${_auto_name//-/_}"
        local _auto_var="DEVBOX_MOUNT_${_auto_key}"
        local _auto_val="${!_auto_var:-}"
        if [[ -z "$_auto_val" ]]; then
            log "Warning: auto-mount '${_auto_name}': DEVBOX_MOUNT_${_auto_key} not set in ${CONFIG_FILE}, skipping."
            continue
        fi
        local _auto_cpath
        _auto_cpath=$(_container_path "$_auto_val")
        if [[ -n "${_claimed[$_auto_cpath]:-}" ]]; then
            log "Warning: auto-mount '${_auto_name}' skipped (container path ${_auto_cpath} already claimed)"
        else
            _arr+=("$_auto_val")
            _claimed["$_auto_cpath"]=1
        fi
    done
}

cmd_create() {
    local name="" pin=false idle_timeout=30 no_auto_mounts=false
    local -a volumes=() raw_mounts=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --pin)             pin=true; shift ;;
            --timeout)         idle_timeout="$2"; shift 2 ;;
            --volume|-v)       volumes+=("$2"); shift 2 ;;
            --mount)           raw_mounts+=("$2"); shift 2 ;;
            --no-auto-mounts)  no_auto_mounts=true; shift ;;
            --help|-h)         _help_create; return 0 ;;
            -*)                die "Unknown flag: $1" ;;
            *)                 [[ -z "$name" ]] || die "Unexpected argument: $1"; name="$1"; shift ;;
        esac
    done

    load_config
    _resolve_mounts volumes "${raw_mounts[@]}"
    [[ "$no_auto_mounts" == false ]] && _apply_auto_mounts volumes

    [[ -z "$name" ]] && name=$(random_name) && log "Generated name: ${name}"
    [[ "$pin" == true ]] && idle_timeout=0

    local container="devbox-${name}"
    local data_dir="${DATA_ROOT}/${name}"
    local existing_state
    existing_state=$(docker inspect "$container" --format '{{.State.Status}}' 2>/dev/null || echo "")

    if [[ "$existing_state" == "running" ]]; then
        die "'${name}' is already running. Use 'devbox reconfigure ${name}' to update its config."
    fi
    if [[ -n "$existing_state" ]]; then
        die "'${name}' is stopped. Use 'devbox start ${name}' to resume it, or 'devbox reconfigure ${name}' to update its config."
    fi
    if [[ -d "$data_dir" ]]; then
        die "'${name}' has orphaned workspace data. Use 'devbox start ${name}' to recreate it."
    fi

    log "Creating '${name}'..."
    _docker_run_devbox "$name" "$pin" "$idle_timeout" "" "${volumes[@]}"
    _print_connection_info "$name" "$(whoami)"
}

cmd_start() {
    local name="${1:-}"
    [[ -n "$name" ]] || { _help_start; return 1; }
    [[ "$name" == "--help" || "$name" == "-h" ]] && { _help_start; return 0; }

    load_config

    local container="devbox-${name}"
    local data_dir="${DATA_ROOT}/${name}"
    local existing_state
    existing_state=$(docker inspect "$container" --format '{{.State.Status}}' 2>/dev/null || echo "")

    if [[ "$existing_state" == "running" ]]; then
        log "'${name}' is already running."
        return 0
    fi

    if [[ -n "$existing_state" ]]; then
        log "Resuming '${name}'..."
        docker start "$container" > /dev/null
        _print_connection_info "$name" "$(whoami)"
        return 0
    fi

    # No container — resurrect from orphaned workspace data
    [[ -d "$data_dir" ]] || die "No devbox named '${name}'. Create it with: devbox create ${name}"

    log "Recreating '${name}' from existing workspace..."

    local pinned idle_timeout=30
    pinned=$(state_get "$name" '.pinned // false')
    [[ "$pinned" == "true" ]] && idle_timeout=0

    local volumes=()
    local _vj
    _vj=$(state_get "$name" '.volumes // []')
    [[ "$_vj" != "[]" ]] && \
        while IFS= read -r _vol; do volumes+=("$_vol"); done < <(jq -r '.[]' <<< "$_vj")

    _docker_run_devbox "$name" "$pinned" "$idle_timeout" "" "${volumes[@]}"
    _print_connection_info "$name" "$(whoami)"
}

cmd_stop() {
    local name="${1:-}"
    [[ -n "$name" ]] || { _help_stop; return 1; }
    [[ "$name" == "--help" || "$name" == "-h" ]] && { _help_stop; return 0; }

    local container="devbox-${name}"
    docker inspect "$container" &>/dev/null || die "No devbox named '${name}'."

    log "Stopping '${name}'..."
    docker stop "$container" > /dev/null
    echo "devbox '${name}' stopped."
}

cmd_reconfigure() {
    local name="" no_auto_mounts=false new_pin="" new_timeout=""
    local -a new_volumes=() raw_mounts=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --pin)             new_pin=true; shift ;;
            --unpin)           new_pin=false; shift ;;
            --timeout)         new_timeout="$2"; shift 2 ;;
            --volume|-v)       new_volumes+=("$2"); shift 2 ;;
            --mount)           raw_mounts+=("$2"); shift 2 ;;
            --help|-h)         _help_reconfigure; return 0 ;;
            -*)                die "Unknown flag: $1" ;;
            *)                 [[ -z "$name" ]] || die "Unexpected argument: $1"; name="$1"; shift ;;
        esac
    done

    [[ -n "$name" ]] || { _help_reconfigure; return 1; }

    load_config
    _resolve_mounts new_volumes "${raw_mounts[@]}"

    local container="devbox-${name}"
    local data_dir="${DATA_ROOT}/${name}"
    local existing_state
    existing_state=$(docker inspect "$container" --format '{{.State.Status}}' 2>/dev/null || echo "")

    if [[ -z "$existing_state" && ! -d "$data_dir" ]]; then
        die "No devbox named '${name}'. Create it with: devbox create ${name}"
    fi

    # Read current stored config
    local cur_pinned
    cur_pinned=$(state_get "$name" '.pinned // false')
    local cur_timeout=30
    [[ "$cur_pinned" == "true" ]] && cur_timeout=0

    # Merge: explicit flags override stored values
    local pin="${new_pin:-$cur_pinned}"
    local idle_timeout="${new_timeout:-$cur_timeout}"
    [[ "$pin" == "true" ]] && idle_timeout=0

    # Start from stored volumes, append new ones (error on container-path collision)
    local volumes=()
    local _vj
    _vj=$(state_get "$name" '.volumes // []')
    [[ "$_vj" != "[]" ]] && \
        while IFS= read -r _vol; do volumes+=("$_vol"); done < <(jq -r '.[]' <<< "$_vj")

    if [[ ${#new_volumes[@]} -gt 0 ]]; then
        local -A _claimed=()
        for _vol in "${volumes[@]}"; do _claimed["$(_container_path "$_vol")"]=1; done
        for _new_vol in "${new_volumes[@]}"; do
            local _cpath
            _cpath=$(_container_path "$_new_vol")
            if [[ -n "${_claimed[$_cpath]:-}" ]]; then
                die "Mount conflict at container path '${_cpath}'. To replace mounts, destroy and recreate."
            fi
            volumes+=("$_new_vol")
            _claimed["$_cpath"]=1
        done
    fi

    # Orphaned: update stored config only; no container to touch
    if [[ -z "$existing_state" ]]; then
        log "Updating config for orphaned '${name}' (no container). Run 'devbox start ${name}' to launch."
        state_set "$name" "pinned" "$([[ "$pin" == "true" ]] && echo 'true' || echo 'false')"
        state_set_volumes "$name" "${volumes[@]}"
        return 0
    fi

    # Has a container — stop if running, remove, recreate (always leaves running)
    if [[ "$existing_state" == "running" ]]; then
        log "Stopping '${name}'..."
        docker stop "$container" > /dev/null
    fi
    log "Removing old container..."
    docker rm "$container" > /dev/null
    remove_tailscale_node "$name"

    log "Recreating '${name}' with updated config..."
    _docker_run_devbox "$name" "$pin" "$idle_timeout" "" "${volumes[@]}"
    _print_connection_info "$name" "$(whoami)"
}

cmd_destroy() {
    local name="${1:-}"
    [[ -n "$name" ]] || { _help_destroy; return 1; }
    [[ "$name" == "--help" || "$name" == "-h" ]] && { _help_destroy; return 0; }

    load_config

    local container="devbox-${name}"
    docker inspect "$container" &>/dev/null || die "No devbox named '${name}'."

    # Stop any active tunnel before removing the container
    local share_active
    share_active=$(state_get "$name" '.share.active // false')
    if [[ "$share_active" == "true" ]]; then
        log "Stopping active tunnel for '${name}'..."
        cmd_unshare "$name" 2>/dev/null || true
    fi

    local status
    status=$(docker inspect "$container" --format '{{.State.Status}}')
    if [[ "$status" == "running" ]]; then
        log "Stopping '${name}'..."
        docker stop "$container" > /dev/null
    fi

    log "Removing container '${name}'..."
    docker rm "$container" > /dev/null

    remove_tailscale_node "$name"
    state_delete "$name"

    echo ""
    echo "devbox '${name}' destroyed."
    echo "  Data preserved at: ${DATA_ROOT}/${name}"
    echo "  To delete data:    devbox purge ${name}"
}

cmd_purge() {
    local name="" yes=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --yes|-y)  yes=true; shift ;;
            --help|-h) _help_purge; return 0 ;;
            -*)        die "Unknown flag: $1" ;;
            *)         [[ -z "$name" ]] || die "Unexpected argument: $1"; name="$1"; shift ;;
        esac
    done

    local -a targets=()

    if [[ -n "$name" ]]; then
        docker inspect "devbox-${name}" &>/dev/null && \
            die "'${name}' still has a container. Run 'devbox destroy ${name}' first."
        [[ -d "${DATA_ROOT}/${name}" ]] || die "No orphaned data found for '${name}'."
        targets=("$name")
    else
        if [[ -d "$DATA_ROOT" ]]; then
            for _dir in "$DATA_ROOT"/*/; do
                [[ -d "$_dir" ]] || continue
                local _dname
                _dname=$(basename "$_dir")
                docker inspect "devbox-${_dname}" &>/dev/null || targets+=("$_dname")
            done
        fi
        if [[ ${#targets[@]} -eq 0 ]]; then
            echo "No orphaned devbox data found."
            return 0
        fi
    fi

    echo "The following devbox data directories will be permanently deleted:"
    for _t in "${targets[@]}"; do
        echo "  ${DATA_ROOT}/${_t}"
    done
    echo ""

    if ! $yes; then
        echo -n "Delete? [y/N] "
        local answer
        read -r answer
        [[ "${answer,,}" == "y" || "${answer,,}" == "yes" ]] || { echo "Aborted."; return 1; }
    fi

    for _t in "${targets[@]}"; do
        rm -rf "${DATA_ROOT}/${_t}"
        state_delete "$_t"
        log "Purged: ${_t}"
    done
}

cmd_share() {
    local name="" port=3000

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --port)    port="$2"; shift 2 ;;
            --help|-h) _help_share; return 0 ;;
            -*)        die "Unknown flag: $1" ;;
            *)         [[ -z "$name" ]] || die "Unexpected argument: $1"; name="$1"; shift ;;
        esac
    done

    [[ -n "$name" ]] || { _help_share; return 1; }

    local container="devbox-${name}"
    local status
    status=$(docker inspect "$container" --format '{{.State.Status}}' 2>/dev/null || echo "")
    [[ "$status" == "running" ]] || die "'${name}' is not running. Start it first with: devbox start ${name}"

    mkdir -p "$LOG_DIR"
    local pid_file="${LOG_DIR}/tunnel-${name}.pid"
    local tunnel_log="${LOG_DIR}/tunnel-${name}.log"

    # Kill any existing tunnel for this devbox
    if [[ -f "$pid_file" ]]; then
        local existing_pid
        existing_pid=$(cat "$pid_file")
        kill "$existing_pid" 2>/dev/null || true
        rm -f "$pid_file"
    fi

    # Resolve the devbox's MagicDNS hostname from the host's Tailscale peer list.
    # MagicDNS hostnames are stable across destroy/recreate; IPs are not.
    local ts_hostname
    ts_hostname=$(tailscale status --json 2>/dev/null \
        | jq -r --arg name "$name" \
            '.Peer[] | select(.HostName == $name) | .DNSName' \
        | head -1 \
        | sed 's/\.$//')   # strip trailing dot

    if [[ -z "$ts_hostname" ]]; then
        # Fallback: try Tailscale IP directly from inside the container
        log "MagicDNS hostname not found in peer list; falling back to Tailscale IP..."
        ts_hostname=$(docker exec "$container" tailscale ip -4 2>/dev/null | head -1 || true)
        [[ -n "$ts_hostname" ]] || die "Could not resolve address for '${name}'. Is Tailscale up inside the container?"
    fi

    log "Starting Cloudflare Tunnel for '${name}' → ${ts_hostname}:${port}..."
    cloudflared tunnel --url "http://${ts_hostname}:${port}" > "$tunnel_log" 2>&1 &
    local tunnel_pid=$!
    echo "$tunnel_pid" > "$pid_file"

    local tunnel_url="" attempts=0
    while [[ $attempts -lt 20 ]]; do
        sleep 2
        tunnel_url=$(grep -oP 'https://[a-z0-9-]+\.trycloudflare\.com' "$tunnel_log" 2>/dev/null | head -1 || true)
        [[ -n "$tunnel_url" ]] && break
        attempts=$(( attempts + 1 ))
    done

    if [[ -z "$tunnel_url" ]]; then
        log "Warning: Could not detect tunnel URL. Check ${tunnel_log}."
        tunnel_url="unknown"
    fi

    state_set_share "$name" "true" "$tunnel_url" "$port"

    echo ""
    echo "Tunnel active for '${name}'"
    echo "  Public URL: ${tunnel_url}"
    echo "  Forwarding: ${tunnel_url} → ${ts_hostname}:${port}"
    echo ""
    echo "To stop: devbox unshare ${name}"
}

cmd_unshare() {
    local name="${1:-}"
    [[ -n "$name" ]] || { _help_unshare; return 1; }
    [[ "$name" == "--help" || "$name" == "-h" ]] && { _help_unshare; return 0; }

    mkdir -p "$LOG_DIR"
    local pid_file="${LOG_DIR}/tunnel-${name}.pid"

    if [[ -f "$pid_file" ]]; then
        local pid
        pid=$(cat "$pid_file")
        kill "$pid" 2>/dev/null && log "Tunnel stopped." || log "Warning: Process ${pid} not found."
        rm -f "$pid_file"
    else
        log "No active tunnel found for '${name}'."
    fi

    state_set_share "$name" "false" "" 3000
    echo "devbox '${name}' unshared."
}

cmd_upgrade() {
    local all=false names=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all)     all=true; shift ;;
            --help|-h) _help_upgrade; return 0 ;;
            -*)        die "Unknown flag: $1" ;;
            *)         names+=("$1"); shift ;;
        esac
    done

    if $all; then
        [[ ${#names[@]} -eq 0 ]] || die "--all takes no name arguments"
        while IFS= read -r container_name; do
            names+=("${container_name#devbox-}")
        done < <(docker ps -a --filter 'name=devbox-' --format '{{.Names}}' 2>/dev/null || true)
        [[ ${#names[@]} -gt 0 ]] || { echo "No devboxes found."; return 0; }
    else
        [[ ${#names[@]} -gt 0 ]] || { _help_upgrade; return 1; }
    fi

    load_config

    local failed=() succeeded=()
    for name in "${names[@]}"; do
        echo "── ${name}"
        if _upgrade_one "$name"; then
            succeeded+=("$name")
        else
            failed+=("$name")
            log "Upgrade of '${name}' failed or was skipped."
        fi
        echo ""
    done

    if [[ ${#names[@]} -gt 1 ]]; then
        echo "Done."
        [[ ${#succeeded[@]} -gt 0 ]] && echo "  OK:     ${succeeded[*]}"
        [[ ${#failed[@]} -gt 0 ]]    && echo "  Skipped/failed: ${failed[*]}"
    fi
}

# Files that can be synced into a running container without full recreate.
# "no-restart"   — takes effect immediately (read fresh each use)
# "needs-restart" — takes effect after container restart (running as a daemon)
_safe_file_restart_mode() {
    case "$1" in
        /usr/local/bin/idle-detect) echo "needs-restart" ;;
        *)                          echo "no-restart" ;;
    esac
}

SAFE_FILES=(
    "/root/CLAUDE.md"
    "/usr/local/bin/idle-detect"
    "/usr/local/bin/install-claude-code"
)

# Compare the running container against the current devbox-base image.
# Prints one of: current | safe-only | unsafe
# Also populates UPGRADE_CHANGED_SAFE (array) and UPGRADE_NEEDS_RESTART (bool).
_analyze_changes() {
    local name="$1" container="devbox-${name}"

    local current_image_id running_image_id
    current_image_id=$(docker inspect devbox-base --format '{{.Id}}' 2>/dev/null) || {
        err "devbox-base image not found. Run: deploy.sh --image-only"
        return 1
    }
    running_image_id=$(docker inspect "$container" --format '{{.Image}}' 2>/dev/null) || return 1

    if [[ "$current_image_id" == "$running_image_id" ]]; then
        UPGRADE_CHANGE_TYPE="current"
        return 0
    fi

    # Create a temporary container from the new image to extract files for comparison
    local temp tmpdir
    temp=$(docker create devbox-base /bin/true 2>/dev/null) || {
        err "Could not create temp container from devbox-base"
        return 1
    }
    tmpdir=$(mktemp -d)
    # shellcheck disable=SC2064
    trap "docker rm -f '$temp' >/dev/null 2>&1; rm -rf '$tmpdir'" RETURN

    # Compare package manifests to detect system-level changes (new apt installs, etc.)
    local packages_changed=false
    docker cp "${temp}:/etc/devbox-manifest" "${tmpdir}/new-manifest" 2>/dev/null || true
    docker exec "$container" cat /etc/devbox-manifest > "${tmpdir}/old-manifest" 2>/dev/null || true
    if ! diff -q "${tmpdir}/new-manifest" "${tmpdir}/old-manifest" >/dev/null 2>&1; then
        packages_changed=true
    fi

    # Compare each safe file between the new image and the running container
    for file in "${SAFE_FILES[@]}"; do
        local fname
        fname=$(basename "$file")
        docker cp "${temp}:${file}" "${tmpdir}/new-${fname}" 2>/dev/null || continue
        docker cp "${container}:${file}" "${tmpdir}/old-${fname}" 2>/dev/null || {
            # File doesn't exist in old container (new addition) — counts as safe change
            UPGRADE_CHANGED_SAFE+=("$file")
            continue
        }
        if ! diff -q "${tmpdir}/new-${fname}" "${tmpdir}/old-${fname}" >/dev/null 2>&1; then
            UPGRADE_CHANGED_SAFE+=("$file")
            [[ "$(_safe_file_restart_mode "$file")" == "needs-restart" ]] && UPGRADE_NEEDS_RESTART=true
        fi
    done

    if $packages_changed; then
        UPGRADE_CHANGE_TYPE="unsafe"
    elif [[ ${#UPGRADE_CHANGED_SAFE[@]} -gt 0 ]]; then
        UPGRADE_CHANGE_TYPE="safe-only"
    else
        UPGRADE_CHANGE_TYPE="no-tracked-changes"
    fi
}

# Copy specific files from the current devbox-base image into a running container
_sync_files() {
    local name="$1" container="devbox-${name}"
    shift
    local files=("$@")

    local temp tmpdir
    temp=$(docker create devbox-base /bin/true 2>/dev/null) || {
        err "Could not create temp container from devbox-base"
        return 1
    }
    tmpdir=$(mktemp -d)
    trap "docker rm -f '$temp' >/dev/null 2>&1; rm -rf '$tmpdir'" RETURN

    for file in "${files[@]}"; do
        local fname
        fname=$(basename "$file")
        docker cp "${temp}:${file}" "${tmpdir}/${fname}" 2>/dev/null && \
        docker cp "${tmpdir}/${fname}" "${container}:${file}" 2>/dev/null && \
            echo "  synced: ${file}" || \
            log "Warning: could not sync ${file}"
    done
}

# Full destroy + recreate from the new image, preserving data and restoring state
_full_recreate() {
    local name="$1" container="devbox-${name}"

    local status was_running=false was_shared=false share_port=3000
    status=$(docker inspect "$container" --format '{{.State.Status}}')
    [[ "$status" == "running" ]] && was_running=true

    local share_active
    share_active=$(state_get "$name" '.share.active // false')
    if [[ "$share_active" == "true" ]]; then
        was_shared=true
        share_port=$(state_get "$name" '.share.port // 80')
        cmd_unshare "$name" 2>/dev/null || true
    fi

    [[ "$status" == "running" ]] && docker stop "$container" > /dev/null
    docker rm "$container" > /dev/null
    remove_tailscale_node "$name"

    if ! $was_running; then
        echo "  '${name}' was stopped — new image will be used on next start."
        return 0
    fi

    local pinned idle_timeout=30
    pinned=$(state_get "$name" '.pinned // false')
    [[ "$pinned" == "true" ]] && idle_timeout=0

    local -a volumes=()
    local _volumes_json
    _volumes_json=$(state_get "$name" '.volumes // []')
    [[ "$_volumes_json" != "[]" ]] && \
        while IFS= read -r _vol; do volumes+=("$_vol"); done \
            < <(jq -r '.[]' <<< "$_volumes_json")

    local recreate_log="${LOG_DIR}/recreate-${name}.log"
    { echo "=== devbox full-recreate: ${name} ==="; echo "=== $(date '+%Y-%m-%d %H:%M:%S') ==="; } >> "$recreate_log"

    if ! _docker_run_devbox "$name" "$pinned" "$idle_timeout" "$recreate_log" "${volumes[@]}"; then
        echo "ERROR: docker run failed at $(date '+%Y-%m-%d %H:%M:%S')" >> "$recreate_log"
        err "Failed to recreate '${name}'."
        err "  Container removed; workspace preserved at: ${DATA_ROOT}/${name}"
        err "  Logs: ${recreate_log}"
        err "  To recreate manually: devbox start ${name}"
        return 1
    fi

    if $was_shared; then
        sleep 5
        cmd_share "$name" --port "$share_port" 2>/dev/null || \
            log "Warning: Could not restart tunnel. Run: devbox share ${name} --port ${share_port}"
    fi

    _print_connection_info "$name" "$(whoami)"
}

_upgrade_one() {
    local name="$1" container="devbox-${name}"
    docker inspect "$container" &>/dev/null || { err "No devbox named '${name}'."; return 1; }

    echo -n "  Analyzing changes... "
    UPGRADE_CHANGED_SAFE=()
    UPGRADE_NEEDS_RESTART=false
    UPGRADE_CHANGE_TYPE=""
    _analyze_changes "$name" || return 1
    local change_type="$UPGRADE_CHANGE_TYPE"

    case "$change_type" in
        current)
            echo "already up to date."
            return 0
            ;;

        no-tracked-changes)
            # Image ID changed (probably a rebuild) but nothing we track differs.
            # Treat as safe-only with nothing to do, but mention it.
            echo "image rebuilt, no file changes detected. Nothing to sync."
            return 0
            ;;

        safe-only)
            # Only known-safe files changed — sync in place, no prompt needed
            echo "safe files changed:"
            for f in "${UPGRADE_CHANGED_SAFE[@]}"; do
                local note=""
                [[ "$(_safe_file_restart_mode "$f")" == "needs-restart" ]] && note=" (needs restart)"
                echo "    ~ $(basename "$f")${note}"
            done
            _sync_files "$name" "${UPGRADE_CHANGED_SAFE[@]}"

            if $UPGRADE_NEEDS_RESTART; then
                echo ""
                echo -n "  Some changes take effect after a restart. Restart now? [Y/n] "
                local answer
                read -r answer
                if [[ "${answer,,}" != "n" ]]; then
                    docker restart "$container"
                    echo "  Restarted."
                fi
            fi
            ;;

        unsafe)
            # System-level changes (packages, etc.) — prompt with three options
            echo "system changes detected (packages or other layers changed)."
            echo ""
            if [[ ${#UPGRADE_CHANGED_SAFE[@]} -gt 0 ]]; then
                echo "  Safe files also changed:"
                for f in "${UPGRADE_CHANGED_SAFE[@]}"; do
                    echo "    ~ $(basename "$f")"
                done
                echo ""
            fi
            echo "  How would you like to upgrade '${name}'?"
            echo "    1) In-place file sync  (safe files only — system changes not applied)"
            echo "    2) Full recreate       (destroy + create from new image — data preserved)"
            echo "    3) Skip"
            echo ""
            echo -n "  Choice [1]: "
            local choice
            read -r choice
            choice="${choice:-1}"

            case "$choice" in
                1)
                    if [[ ${#UPGRADE_CHANGED_SAFE[@]} -gt 0 ]]; then
                        _sync_files "$name" "${UPGRADE_CHANGED_SAFE[@]}"
                        if $UPGRADE_NEEDS_RESTART; then
                            echo -n "  Restart container for daemon changes? [Y/n] "
                            local r; read -r r
                            [[ "${r,,}" != "n" ]] && docker restart "$container" && echo "  Restarted."
                        fi
                    else
                        echo "  No safe files to sync."
                    fi
                    ;;
                2)
                    _full_recreate "$name"
                    ;;
                3)
                    echo "  Skipped."
                    return 1
                    ;;
                *)
                    echo "  Invalid choice. Skipped."
                    return 1
                    ;;
            esac
            ;;
    esac
}

cmd_ssh() {
    local name="${1:-}"
    [[ -n "$name" ]] || { echo "Usage: devbox ssh <name>"; return 1; }
    [[ "$name" == "--help" || "$name" == "-h" ]] && { echo "Usage: devbox ssh <name> [ssh args...]"; return 0; }
    shift

    local status
    status=$(docker inspect "devbox-${name}" --format '{{.State.Status}}' 2>/dev/null || echo "")

    if [[ "$status" != "running" ]]; then
        cmd_start "$name" || return 1
        # wait_for_tailscale_ip (called inside cmd_start) doesn't guarantee sshd is ready yet
        log "Waiting for SSH..."
        local attempts=0
        until ssh -q -o ConnectTimeout=2 -o BatchMode=yes \
                -o StrictHostKeyChecking=no "$(whoami)@${name}" true 2>/dev/null; do
            attempts=$(( attempts + 1 ))
            [[ $attempts -ge 15 ]] && { err "Timed out waiting for SSH on '${name}'."; return 1; }
            sleep 2
        done
    fi

    ssh-keygen -R "$name" &>/dev/null || true
    exec ssh -tt -A -o StrictHostKeyChecking=accept-new "$(whoami)@${name}" "$@"
}

cmd_code() {
    local name="${1:-}"
    [[ -n "$name" ]] || { echo "Usage: devbox code <name>"; return 1; }
    [[ "$name" == "--help" || "$name" == "-h" ]] && { echo "Usage: devbox code <name>"; return 0; }
    exec code --remote "ssh-remote+$(whoami)@${name}" /workspace
}

cmd_zed() {
    local name="${1:-}"
    [[ -n "$name" ]] || { echo "Usage: devbox zed <name>"; return 1; }
    [[ "$name" == "--help" || "$name" == "-h" ]] && { echo "Usage: devbox zed <name>"; return 0; }
    exec zed "ssh://$(whoami)@${name}/workspace"
}

cmd_pin() {
    local name="${1:-}"
    [[ -n "$name" ]] || { _help_pin; return 1; }
    [[ "$name" == "--help" || "$name" == "-h" ]] && { _help_pin; return 0; }

    local current
    current=$(state_get "$name" '.pinned // false')
    local new_val
    [[ "$current" == "true" ]] && new_val="false" || new_val="true"

    state_set "$name" "pinned" "$new_val"

    if [[ "$new_val" == "true" ]]; then
        echo "devbox '${name}' pinned — will not auto-stop."
    else
        echo "devbox '${name}' unpinned — idle detection active."
    fi
}

# ── Help ──────────────────────────────────────────────────────────────────────

cmd_help() {
    local subcmd="${1:-}"
    case "$subcmd" in
        create)      _help_create;      return ;;
        start)       _help_start;       return ;;
        stop)        _help_stop;        return ;;
        reconfigure) _help_reconfigure; return ;;
        destroy)     _help_destroy;     return ;;
        purge)       _help_purge;       return ;;
        share)       _help_share;       return ;;
        unshare)     _help_unshare;     return ;;
        pin)         _help_pin;         return ;;
        upgrade)     _help_upgrade;     return ;;
        list|ls)     _help_list;        return ;;
    esac

    cat <<EOF
devbox — manage devbox containers

Usage:
  devbox <command> [args]

Commands:
  list                     List all devboxes and their status (includes orphans)
  create [name]            Create a new devbox
  start <name>             Start or resurrect a devbox
  stop <name>              Stop a running devbox
  reconfigure <name>       Update mounts, pin, or timeout and recreate
  destroy <name>           Remove a devbox container (data preserved)
  purge [name]             Delete orphaned workspace data permanently
  share <name>             Expose a devbox publicly via Cloudflare Tunnel
  unshare <name>           Stop the Cloudflare Tunnel for a devbox
  pin <name>               Toggle pin state (pinned devboxes never auto-stop)
  upgrade <name>|--all     Recreate devbox(es) from the current base image
  ssh <name>               SSH into a devbox
  code <name>              Open a devbox in VSCode (Remote SSH)
  zed <name>               Open a devbox in Zed (remote)

  help [command]           Show help for a command

Run 'devbox help <command>' for details on a specific command.
EOF
}

_help_create() { cat <<EOF
Usage: devbox create [name] [--pin] [--timeout <minutes>] [--volume <spec>] [--mount <name>] [--no-auto-mounts]

Create a new devbox, or resume an existing stopped one.

If no name is given, a random <adjective>-<noun> name is generated.

Options:
  --pin                Pin the devbox (never auto-stops)
  --timeout <min>      Idle timeout in minutes (default: 30, 0 = pinned)
  --volume, -v <spec>  Bind-mount a volume (host:container[:opts]); repeatable
  --mount <name>       Bind-mount a named volume from config; repeatable
                       Reads DEVBOX_MOUNT_<name> from ${CONFIG_FILE}
                       Dashes in <name> are converted to underscores
  --no-auto-mounts     Skip mounts listed in DEVBOX_AUTO_MOUNTS
  --help               Show this message

Auto-mounts:
  Set DEVBOX_AUTO_MOUNTS in ${CONFIG_FILE} to a space-separated list of named
  mount keys to apply to every new devbox. Explicit --volume/--mount flags win
  if they claim the same container path.

Examples:
  devbox create
  devbox create myproject
  devbox create --pin myserver
  devbox create --timeout 60 myproject
  devbox create --volume /srv/data:/data:ro myproject
  devbox create --mount obsidian-ro myproject
  devbox create --mount obsidian-ro --volume /srv/logs:/logs myproject
  devbox create --no-auto-mounts clean-slate
EOF
}

_help_start() { cat <<EOF
Usage: devbox start <name>

Start a devbox. Behavior depends on current state:

  stopped   — resumes the existing container instantly (docker start)
  orphaned  — creates a new container using stored config and current image
  running   — no-op, prints connection info

To add or change mounts, use 'devbox reconfigure' instead.
EOF
}

_help_stop() { cat <<EOF
Usage: devbox stop <name>

Stop a running devbox. Data is preserved. Resume with 'devbox start <name>'.
EOF
}

_help_reconfigure() { cat <<EOF
Usage: devbox reconfigure <name> [--mount <name>] [--volume <spec>] [--pin] [--unpin] [--timeout <min>]

Update the configuration of an existing devbox and recreate it.

New --mount and --volume flags are appended to the existing mount list.
To replace mounts entirely, destroy and recreate the devbox.

If the devbox is running, it is stopped and restarted automatically.
If the devbox is orphaned (no container), only stored config is updated;
run 'devbox start <name>' afterward to create the container.

Options:
  --mount <name>       Add a named mount from config (DEVBOX_MOUNT_<name>)
  --volume, -v <spec>  Add a bind-mount (host:container[:opts])
  --pin                Pin the devbox (never auto-stops)
  --unpin              Remove pin (restores idle timeout)
  --timeout <min>      Set idle timeout in minutes
  --help               Show this message
EOF
}

_help_destroy() { cat <<EOF
Usage: devbox destroy <name>

Stop and remove a devbox container. The Tailscale node is removed from your
tailnet. Data in ${DATA_ROOT}/<name>/ is always preserved.

To also delete data: devbox purge <name>
EOF
}

_help_purge() { cat <<EOF
Usage: devbox purge [<name>] [--yes]

Permanently delete workspace data for orphaned devboxes — containers that no
longer exist but still have data on disk. Use 'devbox list' to see orphans.

If <name> is given, purge just that devbox's data.
If no name is given, all orphaned data directories are purged.

Options:
  --yes, -y    Skip confirmation prompt
  --help       Show this message

Note: to remove a container while keeping data, use 'devbox destroy <name>'.
EOF
}

_help_share() { cat <<EOF
Usage: devbox share <name> [--port <port>]

Expose a running devbox publicly via a Cloudflare Tunnel.
Requires cloudflared installed on the host.

Options:
  --port <port>    Port to forward (default: 3000)
  --help           Show this message

The tunnel connects via the devbox's MagicDNS hostname (stable across
recreates). The public URL is printed and stored in state for the webapp.
Stop the tunnel with: devbox unshare <name>
EOF
}

_help_unshare() { cat <<EOF
Usage: devbox unshare <name>

Stop the active Cloudflare Tunnel for a devbox.
EOF
}

_help_upgrade() { cat <<EOF
Usage: devbox upgrade <name> [<name> ...]
       devbox upgrade --all

Upgrade one or more devboxes to the current devbox-base image.

devbox upgrade is smart about what changed:

  Safe-files-only change (e.g. CLAUDE.md updated):
    Syncs changed files directly into the running container. No restart
    required for most files; some (like idle-detect) prompt for a restart.
    No data risk, no Tailscale disruption.

  System-level change (e.g. new apt packages in Dockerfile):
    Prompts with three options:
      1) In-place file sync  — apply only the safe file changes
      2) Full recreate       — destroy + create from new image (data preserved)
      3) Skip

Safe files (can always be synced in place):
  /root/CLAUDE.md
  /usr/local/bin/idle-detect
  /usr/local/bin/install-claude-code

Anything installed outside /workspace (apt packages, global npm installs, etc.)
lives in the container layer and requires a full recreate to update.

Options:
  --all     Upgrade all devboxes
  --help    Show this message
EOF
}

_help_pin() { cat <<EOF
Usage: devbox pin <name>

Toggle the pin state of a devbox. Pinned devboxes never auto-stop due to
idle detection. Unpinned devboxes stop after DEVBOX_IDLE_TIMEOUT minutes
of inactivity (default: 30m).

Note: The idle timeout change takes effect on the next start.
EOF
}

_help_list() { cat <<EOF
Usage: devbox list

List all devboxes with their status, pin state, and share URL.
EOF
}

# ── Shared output ─────────────────────────────────────────────────────────────

_print_connection_info() {
    local name="$1" ssh_user="${2:-root}"
    log "Waiting for Tailscale IP..."
    local ts_ip
    ts_ip=$(wait_for_tailscale_ip "$name")
    [[ -z "$ts_ip" ]] && ts_ip="unknown (still connecting)"

    local pinned
    pinned=$(state_get "$name" '.pinned // false')

    local volumes_json
    volumes_json=$(state_get "$name" '.volumes // []')

    echo ""
    echo "devbox '${name}' is ready"
    echo "  ssh ${ssh_user}@${name}"
    echo "  Tailscale IP: ${ts_ip}"
    echo "  Data: ${DATA_ROOT}/${name}"
    [[ "$pinned" == "true" ]] \
        && echo "  Pinned: yes (will not auto-stop)" \
        || echo "  Idle timeout: ${DEVBOX_IDLE_TIMEOUT:-30}m"
    if [[ "$volumes_json" != "[]" ]] && [[ -n "$volumes_json" ]]; then
        echo "  Volumes:"
        while IFS= read -r _vol; do echo "    $_vol"; done \
            < <(jq -r '.[]' <<< "$volumes_json")
    fi
}

# ── Dispatch ──────────────────────────────────────────────────────────────────

COMMAND="${1:-}"
[[ $# -gt 0 ]] && shift || true

case "$COMMAND" in
    list|ls)            cmd_list        "$@" ;;
    create)             cmd_create      "$@" ;;
    start)              cmd_start       "$@" ;;
    stop)               cmd_stop        "$@" ;;
    reconfigure)        cmd_reconfigure "$@" ;;
    destroy)            cmd_destroy     "$@" ;;
    purge)              cmd_purge       "$@" ;;
    share)              cmd_share   "$@" ;;
    unshare)            cmd_unshare "$@" ;;
    pin)                cmd_pin     "$@" ;;
    upgrade)            cmd_upgrade "$@" ;;
    ssh)                cmd_ssh     "$@" ;;
    code)               cmd_code    "$@" ;;
    zed)                cmd_zed     "$@" ;;
    help|--help|-h)     cmd_help    "$@" ;;
    "")                 cmd_help;   exit 1 ;;
    *)  err "unknown command: '${COMMAND}'"; echo "Run 'devbox help' for usage." >&2; exit 1 ;;
esac
